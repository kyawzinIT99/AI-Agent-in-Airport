# ── AI (required) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── GitHub (optional — enables commit reports) ────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# ── Jira (optional — enables issue reports) ───────────────────────────────────
JIRA_SERVER=yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=ENG

# ── Database ───────────────────────────────────────────────────────────────────
# Default: sqlite:///./database/agentoffice.db  (created automatically)
# DATABASE_URL=sqlite:///./database/agentoffice.db

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Daily agent run time (UTC). Default: 09:00
# SCHEDULER_HOUR=9
# SCHEDULER_MINUTE=0
